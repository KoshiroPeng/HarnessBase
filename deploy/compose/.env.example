COMPOSE_PROJECT_NAME=harness-base

# 中文说明：运行环境名称，对应 Spring profile。
RUOYI_PROFILE=dev

# 中文说明：对外暴露端口，可按环境调整。
NGINX_HTTP_PORT=80
GATEWAY_HTTP_PORT=8080
NACOS_HTTP_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
MONITOR_HTTP_PORT=9100
FILE_HTTP_PORT=9300

# 中文说明：基础中间件默认凭据，生产环境必须替换。
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=ry-cloud
MYSQL_NACOS_DATABASE=ry-config
REDIS_PASSWORD=

# 中文说明：Nacos 认证参数，若开启鉴权需在目标环境替换为正式值。
NACOS_AUTH_ENABLE=false
NACOS_AUTH_TOKEN=change_me_nacos_token
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security

# 中文说明：服务运行与对外访问配置。
JAVA_OPTS="-Xms512m -Xmx1024m"
PUBLIC_BASE_URL=http://localhost
FILE_SERVICE_PUBLIC_URL=http://localhost:9300
FILE_UPLOAD_PATH=./data/uploadPath
