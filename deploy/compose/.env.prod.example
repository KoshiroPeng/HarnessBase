COMPOSE_PROJECT_NAME=harness-base-prod

# 中文说明：生产环境建议使用 prod profile，同时在 Nacos 中同步维护 application-prod.yml 和各服务 *-prod.yml。
RUOYI_PROFILE=prod

# 中文说明：生产环境端口示例，可按现场统一入口调整。
NGINX_HTTP_PORT=80
GATEWAY_HTTP_PORT=8080
SENTINEL_DASHBOARD_PORT=8718
NACOS_HTTP_PORT=8848
NACOS_CONSOLE_PORT=8081
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
MONITOR_HTTP_PORT=9100
FILE_HTTP_PORT=9300

# 中文说明：生产环境必须替换为正式值。
MYSQL_ROOT_PASSWORD=replace_with_prod_root_password
MYSQL_DATABASE=ry-cloud
MYSQL_NACOS_DATABASE=ry-config
REDIS_PASSWORD=

# 中文说明：如果生产环境启用 Nacos 鉴权，请同步调整为正式密钥。
NACOS_AUTH_ENABLE=false
NACOS_AUTH_TOKEN=replace_with_prod_nacos_token
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security

JAVA_OPTS="-Xms1024m -Xmx2048m"
SENTINEL_JAVA_OPTS="-Xms256m -Xmx512m"
PUBLIC_BASE_URL=https://admin.example.com
FILE_SERVICE_PUBLIC_URL=https://admin.example.com/file
FILE_UPLOAD_PATH=./data/uploadPath
