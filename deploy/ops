#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/compose.yml"
APP_COMPOSE_FILE="$SCRIPT_DIR/compose.app.yml"

compose_files=("-f" "$COMPOSE_FILE")
if [[ "${2:-}" == "--app" || "${1:-}" == "--app" ]]; then
  compose_files+=("-f" "$APP_COMPOSE_FILE")
fi
if [[ "${1:-}" == "--app" ]]; then
  shift
fi

usage() {
  cat <<'USAGE'
Usage:
  ./deploy/ops start       Start infrastructure containers
  ./deploy/ops start --app Start infrastructure + application containers
  ./deploy/ops stop        Stop containers
  ./deploy/ops restart     Restart containers
  ./deploy/ops build       Build application images
  ./deploy/ops status      Show container status
  ./deploy/ops logs [svc]  Show logs
  ./deploy/ops health      Run basic health checks
USAGE
}

compose() {
  docker compose --project-directory "$REPO_ROOT" "${compose_files[@]}" "$@"
}

case "${1:-}" in
  start)
    compose up -d
    ;;
  stop)
    compose down
    ;;
  restart)
    compose down
    compose up -d
    ;;
  build)
    docker compose --project-directory "$REPO_ROOT" -f "$COMPOSE_FILE" -f "$APP_COMPOSE_FILE" build
    ;;
  status)
    compose ps
    ;;
  logs)
    shift || true
    compose logs -f --tail=200 "$@"
    ;;
  health)
    compose ps
    echo
    docker exec callcenter-mysql mysqladmin ping -h 127.0.0.1 -uroot -proot --silent
    docker exec callcenter-redis redis-cli -a ruoyi123 ping
    curl -fsS http://localhost:9000/minio/health/live >/dev/null && echo "minio OK"
    if docker ps --format '{{.Names}}' | grep -q '^callcenter-admin$'; then
      curl -fsS -u callcenter:123456 http://localhost:8080/actuator/health >/dev/null && echo "admin OK"
    fi
    if docker ps --format '{{.Names}}' | grep -q '^callcenter-web$'; then
      curl -fsS http://localhost/ >/dev/null && echo "web OK"
    fi
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
